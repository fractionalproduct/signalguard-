{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "cd ../.. && pnpm --filter \"@signalguard/web...\" build",
  "crons": [
    {
      "path": "/api/cron/watchlist-analysis",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/discovery",
      "schedule": "0 13,17 * * 1-5"
    },
    {
      "path": "/api/cron/proposal-expiry",
      "schedule": "15 * * * *"
    },
    {
      "path": "/api/cron/autopilot",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/cron/execute-orders",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/ta-ingest",
      "schedule": "0 */1 * * 1-5"
    },
    {
      "path": "/api/cron/reconcile-orders",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/position-monitor",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/option-monitor",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/option-exits",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/options-autopilot",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/cron/evening-briefing",
      "schedule": "0 22 * * *"
    },
    {
      "path": "/api/cron/ai-summaries",
      "schedule": "*/30 * * * 1-5"
    },
    {
      "path": "/api/cron/political-trades",
      "schedule": "0 14 * * 1-5"
    }
  ]
}
