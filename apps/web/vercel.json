{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "cd ../.. && pnpm --filter \"@signalguard/web...\" build",
  "crons": [
    {
      "path": "/api/cron/watchlist-analysis",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/proposal-expiry",
      "schedule": "15 * * * *"
    },
    {
      "path": "/api/cron/execute-orders",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/reconcile-orders",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/position-monitor",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/evening-briefing",
      "schedule": "0 22 * * *"
    }
  ]
}
