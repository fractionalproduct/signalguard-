# TradingAgents sidecar — environment template.
#
# ============================================================================
# HARD RULES (docs/tradingagents-supply-chain-review.md, M3 + control 3):
#   - Put ONLY what is below in the real .env: the SignalGuard ingest URL/token
#     and exactly ONE Western LLM key.
#   - NEVER put SignalGuard app / database / Alpaca broker / session secrets
#     here. This host never gets them and never needs them.
#   - NO Chinese LLM providers (DeepSeek / Qwen / GLM / MiniMax / Moonshot).
#     The egress allowlist in docker-compose.yml blocks them at the network too.
#   - Use a DEDICATED, billing-CAPPED LLM key (throwaway account). The debate
#     loop calls the LLM many times per ticker — a hard spend cap prevents a
#     billing-DoS even absent a bug (control 5).
# ============================================================================

# --- SignalGuard ingest -------------------------------------------------------
# The candidates endpoint (PART 1). e.g. https://<your-app>.vercel.app/api/ta/candidates
SIGNALGUARD_INGEST_URL=

# Bearer token for the ingest endpoint. This is the SAME value as SignalGuard's
# CRON_SECRET (the endpoint is gated by the cron auth check). Treat as a secret.
SIGNALGUARD_INGEST_TOKEN=

# --- LLM provider (pick ONE Western provider + its ONE key) -------------------
# Allowed values: openai | anthropic | google | xai | ollama
TA_LLM_PROVIDER=openai

# Provide ONLY the key matching TA_LLM_PROVIDER above. Leave the others unset.
# (TradingAgents reads the key from the provider's standard env var.)
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
# XAI_API_KEY=
# (ollama: no key — runs locally on this host, zero data egress)

# --- Optional model + cost knobs (validated config keys) ----------------------
# Defaults (TradingAgents v0.2.5): openai / deep gpt-5.5 / quick gpt-5.4-mini.
# For a non-OpenAI provider you MUST set models its API accepts:
# TA_DEEP_LLM=        # e.g. claude-... / gemini-... / grok-... / (ollama model)
# TA_QUICK_LLM=
# TA_BACKEND_URL=     # REQUIRED for ollama / a self-hosted OpenAI-compatible endpoint
# Cost guards (the debate loop calls the LLM many times/ticker):
# TA_MAX_DEBATE_ROUNDS=1
# TA_MAX_RECUR_LIMIT=30

# --- News data providers (optional — for the "aggregate" news vendor) ----------
# These are DATA-API keys (not LLM keys, not Chinese) — separate from the single
# LLM key rule above. The news analyst uses the "aggregate" vendor by default
# (TA_NEWS_VENDOR), which fans out to every provider whose key is present plus the
# keyless ones. Provide the keys you want active; omit the rest and that source is
# simply skipped. With none set, aggregate still runs GDELT + yfinance (keyless).
#   Finnhub   — finnhub.io (free tier, 60/min)
# FINNHUB_API_KEY=
#   Marketaux — marketaux.com (free ~100/day; Reuters/Bloomberg-headline substitute)
# MARKETAUX_API_KEY=
#   EODHD     — eodhd.com (paid)
# EODHD_API_KEY=
#   GDELT     — keyless (no var). FRED (macro) uses FRED_API_KEY if you enable macro.
# TA_NEWS_VENDOR=aggregate   # or e.g. "finnhub,marketaux,gdelt,yfinance" for ordered fallback

# --- Work source --------------------------------------------------------------
# Where this run gets its symbols (D4-B):
#   watchlist (default): nominate over the static WATCHLIST_SYMBOLS below. In this
#     mode the posted candidate's `action` IS TradingAgents' own verdict.
#   queue: PULL discovery-driven work items from SignalGuard's analysis queue
#     (GET /api/ta/analysis-queue). In this mode `action` is SignalGuard's
#     discovery INTENT (from the queue item) and `taVerdict` is TradingAgents'
#     opinion — they may differ. WATCHLIST_SYMBOLS is NOT required in queue mode.
TA_SOURCE=watchlist

# Max work items to claim per pull in queue mode (server caps at 50). Default 10.
# TA_QUEUE_LIMIT=10

# Pull endpoint base, used in queue mode only. Optional: if unset it is derived
# by stripping the path off SIGNALGUARD_INGEST_URL (same host, same bearer token,
# no new creds). Set it only if the pull endpoint lives on a different host.
# SIGNALGUARD_INGEST_BASE=https://<your-app>.vercel.app

# --- Watchlist ----------------------------------------------------------------
# Comma-separated symbols to nominate over (watchlist mode). Should match (a
# subset of) the SignalGuard WATCHLIST_SYMBOLS — off-watchlist nominations are
# dropped at ta-ingest, so emitting them just wastes LLM spend.
WATCHLIST_SYMBOLS=AAPL,MSFT,NVDA
