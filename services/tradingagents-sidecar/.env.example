# TradingAgents sidecar — environment template.
#
# ============================================================================
# HARD RULES (docs/tradingagents-supply-chain-review.md, M3 + control 3):
#   - Put ONLY what is below in the real .env: the SignalGuard ingest URL/token
#     and exactly ONE Western LLM key.
#   - NEVER put SignalGuard app / database / Alpaca broker / session secrets
#     here. This host never gets them and never needs them.
#   - NO Chinese LLM providers (DeepSeek / Qwen / GLM / MiniMax / Moonshot).
#     The egress allowlist in docker-compose.yml blocks them at the network too.
#   - Use a DEDICATED, billing-CAPPED LLM key (throwaway account). The debate
#     loop calls the LLM many times per ticker — a hard spend cap prevents a
#     billing-DoS even absent a bug (control 5).
# ============================================================================

# --- SignalGuard ingest -------------------------------------------------------
# The candidates endpoint (PART 1). e.g. https://<your-app>.vercel.app/api/ta/candidates
SIGNALGUARD_INGEST_URL=

# Bearer token for the ingest endpoint. This is the SAME value as SignalGuard's
# CRON_SECRET (the endpoint is gated by the cron auth check). Treat as a secret.
SIGNALGUARD_INGEST_TOKEN=

# --- LLM provider (pick ONE Western provider + its ONE key) -------------------
# Allowed values: openai | anthropic | google | xai | ollama
TA_LLM_PROVIDER=openai

# Provide ONLY the key matching TA_LLM_PROVIDER above. Leave the others unset.
# (TradingAgents reads the key from the provider's standard env var.)
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
# XAI_API_KEY=
# (ollama: no key — runs locally on this host, zero data egress)

# --- Optional model + cost knobs (validated config keys) ----------------------
# Defaults (TradingAgents v0.2.5): openai / deep gpt-5.5 / quick gpt-5.4-mini.
# For a non-OpenAI provider you MUST set models its API accepts:
# TA_DEEP_LLM=        # e.g. claude-... / gemini-... / grok-... / (ollama model)
# TA_QUICK_LLM=
# TA_BACKEND_URL=     # REQUIRED for ollama / a self-hosted OpenAI-compatible endpoint
# Cost guards (the debate loop calls the LLM many times/ticker):
# TA_MAX_DEBATE_ROUNDS=1
# TA_MAX_RECUR_LIMIT=30

# --- Watchlist ----------------------------------------------------------------
# Comma-separated symbols to nominate over. Should match (a subset of) the
# SignalGuard WATCHLIST_SYMBOLS — off-watchlist nominations are dropped at
# ta-ingest, so emitting them just wastes LLM spend.
WATCHLIST_SYMBOLS=AAPL,MSFT,NVDA
