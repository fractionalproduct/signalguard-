# =============================================================================
# SignalGuard AI — Environment Variable Template
# =============================================================================
# HOW TO USE:
#   1. Copy this file to ".env"  (the real .env is NEVER committed to Git).
#   2. Fill in real values for the services you have set up so far.
#   3. Leave the rest blank until that milestone is reached.
#
# SECURITY: Never paste real secret values into a chat, a pull request, or
# anywhere public. Real values belong ONLY in:
#   - your local .env file (ignored by Git), or
#   - the host's encrypted "Environment Variables" / "Secrets" settings.
# =============================================================================

# ---- Core ----
NODE_ENV=development
APP_BASE_URL=http://localhost:3000
# Generate a long random string for signing sessions (do NOT reuse anywhere).
SESSION_SECRET=

# ---- PostgreSQL (Supabase) ----  [Milestone 1]
# From Supabase → Connect → ORM tab. DATABASE_URL = pooled (port 6543),
# DIRECT_URL = direct/session (port 5432, used for migrations).
DATABASE_URL=
DIRECT_URL=

# ---- Redis (Upstash) ----  [Milestone 1]
REDIS_URL=

# ---- AI provider (start with ONE) ----  [Milestone 4]
# AI_PROVIDER is "openai" or "anthropic"
AI_PROVIDER=anthropic
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ---- Alpaca PAPER trading ONLY ----  [Milestone 3]
# These MUST be paper-trading keys. The base URL must be the paper endpoint.
ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
# Hard safety flag — the app refuses to run trading against a live endpoint.
TRADING_MODE=paper

# ---- Email (Resend) ----  [Milestone 2 / 15]
RESEND_API_KEY=
EMAIL_FROM=

# ---- Error monitoring (Sentry) ----  [Milestone 2]
SENTRY_DSN=

# ---- Market data provider ----  [Milestone 8]
MARKET_DATA_PROVIDER=
MARKET_DATA_API_KEY=

# ---- Object storage (Cloudflare R2 / S3) ----  [Milestone 8]
STORAGE_ENDPOINT=
STORAGE_BUCKET=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=

# ---- Social sources ----  [Milestone 5 / later]
X_API_BEARER_TOKEN=
TELEGRAM_BOT_TOKEN=

# ---- Owner bootstrap (used once by `pnpm create-owner`) ----
OWNER_EMAIL=
