// SignalGuard AI — initial data model (Milestone 1).
// Expanded in later milestones (signals, orders, positions, performance, etc.).
// PostgreSQL is the system of record (see docs/architecture.md).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Pooled connection (Supabase transaction pooler, port 6543) for app runtime.
  url       = env("DATABASE_URL")
  // Direct/session connection (port 5432) for migrations & `prisma db push`.
  directUrl = env("DIRECT_URL")
}

/// The single platform owner. Public registration is disabled; the owner is
/// created once via `pnpm create-owner` (Milestone 2). Passwords and MFA secrets
/// are stored hashed/encrypted only — never plaintext.
model Owner {
  id                 String    @id @default(cuid())
  email              String    @unique
  passwordHash       String?
  mfaEnabled         Boolean   @default(false)
  /// TOTP secret, encrypted at rest (AES-256-GCM). Never stored in plaintext.
  mfaSecretEncrypted String?
  mfaEnabledAt       DateTime?
  passwordChangedAt  DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  auditEvents         AuditEvent[]
  sessions            Session[]
  recoveryCodes       RecoveryCode[]
  passwordResetTokens PasswordResetToken[]
}

/// An authenticated browser session. The raw token lives only in the owner's
/// HTTP-only cookie; only its SHA-256 hash is stored here.
model Session {
  id         String    @id @default(cuid())
  ownerId    String
  owner      Owner     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique
  createdAt  DateTime  @default(now())
  expiresAt  DateTime
  lastUsedAt DateTime?
  revokedAt  DateTime?
  ipAddress  String?
  userAgent  String?

  @@index([ownerId])
  @@index([expiresAt])
}

/// One-time MFA recovery codes. Only the hash is stored; consumed on use.
model RecoveryCode {
  id        String    @id @default(cuid())
  ownerId   String
  owner     Owner     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  codeHash  String
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([ownerId])
}

/// Short-lived password-reset tokens. Raw token emailed; only its hash stored.
model PasswordResetToken {
  id        String    @id @default(cuid())
  ownerId   String
  owner     Owner     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([ownerId])
}

/// Append-only audit trail. Every security-, trading-, and guardrail-sensitive
/// action writes a record here. Records are never updated or deleted.
model AuditEvent {
  id        String   @id @default(cuid())
  /// Stable event type, e.g. "owner.login", "emergency_stop.activated".
  type      String
  /// Logical service that emitted the event: web | general-worker | trading-worker.
  source    String
  /// Optional actor (owner) the event is attributed to.
  ownerId   String?
  owner     Owner?   @relation(fields: [ownerId], references: [id])
  /// Free-form structured context (no secrets).
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([type])
  @@index([createdAt])
  @@index([ownerId])
}

/// Single-row global kill switch (AGENTS.md §14). When `active`, the execution
/// worker MUST NOT submit new orders. M12 only READS this flag; the activation
/// UI, cancel-unfilled, and protective-exit handling are M16. Enforced as a
/// singleton via the fixed id "global".
model EmergencyStop {
  id        String   @id @default("global")
  active    Boolean  @default(false)
  reason    String?
  /// Owner who last toggled it, for audit. Null for system/default.
  updatedBy String?
  updatedAt DateTime @updatedAt
}

/// Owner-configurable autonomous-trading controls. Singleton (single-owner app),
/// mirroring EmergencyStop. Every knob is intentionally conservative by default;
/// autopilot is OFF and SHADOW until the owner explicitly arms it. Money in cents.
model AutopilotConfig {
  id String @id @default("global")

  /// Master switch. When false, the autonomous engine does nothing at all.
  enabled Boolean @default(false)
  /// Decide-and-log only: the engine evaluates + records what it WOULD do but
  /// never approves/submits. The safe default; arming = setting this false.
  shadowMode Boolean @default(true)

  /// Daily controls (the owner-facing limits). Null = that limit is disabled.
  /// Max capital DEPLOYED (gross entry notional of new positions) per ET day.
  dailyCapitalCapCents Int?
  /// Realized-profit "profit-lock": once net realized P&L today reaches this,
  /// stop opening new positions for the day (protective exits untouched).
  dailyProfitTargetCents Int?
  profitLockEnabled Boolean @default(true)
  /// Cap on new positions opened per ET day. Null = use the risk profile default.
  maxNewPositionsPerDay Int?

  /// Owner opt-in to trade PRE_MARKET / AFTER_HOURS (manual path only — the
  /// autonomous engine stays regular-session-only). Default false = regular only.
  extendedHoursEnabled Boolean @default(false)

  /// Auto-approval gate thresholds (a proposal must clear ALL of these).
  minProbability    Float @default(0.6)
  minConfidence     Float @default(0.7)
  /// Minimum expected value in R multiples (reward/risk-weighted by probability).
  minExpectedValueR Float @default(0.1)
  /// Reject proposals older than this many seconds (signal-freshness TTL).
  /// 1h default: proposals are generated hourly, so a short TTL would make them
  /// eligible only briefly. Configurable.
  maxSignalAgeSeconds Int @default(3600)

  /// MANUAL = every proposal needs owner approval; AUTOMATIC = TA-sourced
  /// proposals may auto-approve when not escalated. Only meaningful when
  /// autopilot is armed.
  tradingMode String @default("MANUAL")

  updatedBy String?
  updatedAt DateTime @updatedAt
}

/// A tradable option contract (long single-leg, M17 — docs/options-scope.md).
/// Equity tables are deliberately untouched; options live in their own Option*
/// models so no equity code path branches on multiplier / expiry / option
/// semantics. Money in integer cents.
model OptionContract {
  id String @id @default(cuid())
  /// Canonical OCC symbol, e.g. "META260718C00720000". Unique.
  occSymbol String @unique
  /// Equity ticker the option is on, e.g. "META" (SAME universe as equities).
  underlying String
  /// "CALL" | "PUT".
  right String
  /// Strike price in integer cents (e.g. $720.00 -> 72000).
  strikeCents Int
  /// Expiration date (the option dies at this date's market close).
  expiration DateTime
  /// Shares per contract — always 100. All P&L = price x multiplier x contracts.
  multiplier Int @default(100)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  positions OptionPosition[]

  @@index([underlying, expiration])
}

/// A LONG option position (M17). `contracts` is the live source of truth; the
/// maximum loss is bounded at `premiumPaidCents` (the debit paid — no
/// assignment/margin for long single-leg). Mirrors the equity Position
/// lifecycle (OPEN -> CLOSING -> CLOSED).
model OptionPosition {
  id String @id @default(cuid())
  optionContractId String
  optionContract OptionContract @relation(fields: [optionContractId], references: [id])
  /// Live contract count (source of truth, like equity Position.quantity).
  contracts Int
  /// Average premium paid PER SHARE, in cents.
  avgPremiumPaidCents Int
  /// Total cost basis = contracts x avgPremiumPaidCents x multiplier. Also the
  /// maximum loss (a long option can go to zero).
  premiumPaidCents Int
  /// "OPEN" | "CLOSING" | "CLOSED".
  status String @default("OPEN")
  openedAt DateTime @default(now())
  closedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, openedAt])
}

/// Owner-configurable options risk + exit thresholds (M17). Singleton, mirroring
/// AutopilotConfig. A superset of the lib OptionRiskConfig + OptionExitConfig, so
/// the row can be passed straight to evaluateOptionEntry + decideOptionExit.
/// Defaults match the lib DEFAULT_OPTION_RISK_CONFIG / DEFAULT_OPTION_EXIT_CONFIG.
model OptionConfig {
  id String @id @default("global")

  // Entry risk gate
  minDte                  Int    @default(7)
  maxDte                  Int    @default(45)
  maxSpreadBps            Int    @default(800)
  minOpenInterest         Int    @default(500)
  minPremiumCents         Int    @default(10)
  maxPremiumPerTradeCents Int    @default(50000)
  minMarkCents            Int    @default(10)
  /// IV caution ceiling (percent). Null = IV gate disabled.
  maxIvPercent            Float?

  // Exits
  mustCloseByDte  Int   @default(3)
  profitTargetPct Float @default(0.4)
  timeStopDte     Int   @default(5)
  softStopPct     Float @default(0.5)

  updatedBy String?
  updatedAt DateTime @updatedAt
}

/// Autonomous OPTIONS engine config (M17) — DELIBERATELY SEPARATE from
/// AutopilotConfig and STRICTER than the manual OptionConfig (docs/options-scope §9).
/// Default OFF + SHADOW. A superset of the lib OptionRiskConfig (the stricter
/// gate) plus the autonomous caps, so it passes straight to evaluateOptionEntry.
model OptionAutopilotConfig {
  id String @id @default("global")

  /// Master switch — the engine does nothing when false.
  enabled Boolean @default(false)
  /// Decide-and-log only (never places an order). The safe default; arming the
  /// autonomous options buyer is a deliberate, separate, later step.
  shadowMode Boolean @default(true)

  /// Autonomous caps (in addition to the per-trade gate).
  maxConcurrentOptionPositions Int @default(3)
  maxAggregatePremiumAtRiskCents Int @default(100000)

  /// Stricter entry gate than manual OptionConfig (tighter DTE/spread/liquidity,
  /// smaller per-trade premium). Same shape as OptionRiskConfig.
  minDte                  Int    @default(21)
  maxDte                  Int    @default(45)
  maxSpreadBps            Int    @default(500)
  minOpenInterest         Int    @default(1000)
  minPremiumCents         Int    @default(10)
  maxPremiumPerTradeCents Int    @default(30000)
  minMarkCents            Int    @default(10)
  maxIvPercent            Float?

  updatedBy String?
  updatedAt DateTime @updatedAt
}

/// Cache of AlphaVantage insider-transaction data per symbol. AlphaVantage's
/// free tier is ~25 requests/day, so the loader serves from here within a TTL
/// instead of fetching on every research-page view. `payload` is the mapped
/// InsiderTransaction[] JSON.
model InsiderTransactionCache {
  symbol    String   @id
  payload   Json
  fetchedAt DateTime @default(now())
}

/// A trade-symbol candidate from the TradingAgents sidecar
/// (docs/tradingagents-integration-review.md). The sidecar WRITES these; the
/// ta-ingest cron consumes NEW ones, runs OUR M9 scan on the symbol, and creates
/// a proposal (source="TRADING_AGENTS"). TradingAgents is a SYMBOL NOMINATOR — it
/// never supplies prices/probability/sizing; we recompute everything. thesisText
/// is UNTRUSTED (attacker-influenced news/social) → proposal.notes only.
model TaCandidate {
  id String @id @default(cuid())
  /// Idempotency / dedup key from the sidecar run. Unique.
  agentRunId String @unique
  symbol String
  /// "BUY" | "SELL" | "HOLD" — only BUY survives (long-only).
  action String
  /// The model's own conviction (0..1). Advisory only; NOT pTargetFirstPoint.
  confidenceHint Float?
  /// Untrusted free-text rationale — lands in proposal.notes, never parsed.
  thesisText String?
  asOfDate DateTime
  /// "NEW" | "INGESTED" | "DROPPED".
  status String @default("NEW")
  /// Why dropped (off_watchlist / not_buy / scan_failed), for audit.
  dropReason String?
  /// TradingAgents' OWN BUY/SELL/HOLD opinion — DISTINCT from `action` (the
  /// originating intent). Display/conflict metadata only; NEVER gates the drop
  /// decision (a BUY with taVerdict "SELL" is still ingested as conflict data).
  taVerdict String?
  /// The multi-LLM vote tally behind the verdict. Display/metadata only.
  consensusTally Json?
  /// The full analyst reports (market/sentiment/news/fundamentals/bull-bear/
  /// trader plan). Display/metadata only; never parsed for control.
  analysisReport Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
}

/// The TradingAgents analysis work queue (D4-B, discovery-driven mode). When the
/// sidecar runs in `queue` mode it PULLS items from here (via GET
/// /api/ta/analysis-queue) instead of nominating from a static watchlist. The
/// row carries SignalGuard's DISCOVERY INTENT for a symbol — `action` is what SG
/// wants TradingAgents to evaluate (default "BUY"), NOT TradingAgents' own
/// opinion. TradingAgents' opinion comes back later as TaCandidate.taVerdict and
/// MAY differ (action=BUY, taVerdict=SELL is a kept conflict, never a drop).
///
/// The sidecar has NO DB creds — it only ever reads the claimed items through the
/// token-gated HTTP endpoint. Producers (SG discovery / a manual seed / a
/// watchlist-seed cron) write here via enqueueTaAnalysis. Status is a plain
/// string ("PENDING" | "CLAIMED" | "DONE"), not a Prisma enum, so new states stay
/// migration-free. No @@unique on (symbol,status) — that is too strict across DONE
/// rows; PENDING dedupe is enforced in enqueueTaAnalysis instead.
model TaAnalysisQueue {
  id String @id @default(cuid())
  symbol String
  /// SignalGuard's discovery intent for this symbol — "BUY" by default. This is
  /// NOT the LLM verdict; it is never overwritten by TradingAgents' opinion.
  action String @default("BUY")
  /// Why SG queued this symbol (e.g. "MOVERS", "manual-seed"), for audit. Free
  /// text from a trusted producer; display/metadata only.
  discoveryReason String?
  /// "PENDING" (awaiting pull) | "CLAIMED" (handed to the sidecar) | "DONE".
  status String @default("PENDING")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
}

// --- Milestone 5: source intelligence & signals --------------------------------
// Mirrors the types in @signalguard/domain. Source content is treated as hostile
// data; instructions inside it are never executed (AGENTS.md §2). No connector
// runs without an APPROVED_FOR_PRODUCTION DataSourceConfiguration in production
// (AGENTS.md §15, docs/data-licensing.md).

/// Licensing approval for a data provider/dataset. The authoritative enum lives
/// in @signalguard/domain (DataSourceApprovalStatus) — keep the two in sync.
enum DataSourceApprovalStatus {
  NOT_REVIEWED
  PENDING_REVIEW
  APPROVED_FOR_DEVELOPMENT
  APPROVED_FOR_PRODUCTION
  REJECTED
  SUSPENDED
}

/// How a source's content is obtained. Only MANUAL and MOCK run in the MVP.
enum SourceKind {
  MANUAL
  MOCK
  X
  TELEGRAM
  RSS
  CONGRESS
}

/// Congressional chamber a filing originates from (M6).
enum Chamber {
  HOUSE
  SENATE
}

/// Reported transaction type on a congressional periodic transaction report.
enum CongressionalTransactionType {
  PURCHASE
  SALE
  EXCHANGE
}

/// Lifecycle of an extracted signal. Mirrors SignalStatus in @signalguard/domain.
enum SignalStatus {
  NEW
  PROCESSING
  READY_FOR_REVIEW
  APPROVED
  REJECTED
  EXPIRED
  ARCHIVED
}

/// Per-provider licensing record. Every Source references exactly one; no
/// connector runs without it, and production needs APPROVED_FOR_PRODUCTION.
model DataSourceConfiguration {
  id                  String                   @id @default(cuid())
  provider            String
  dataset             String
  terms               String
  permittedUses       String
  prohibitedUses      String
  storageRights       String
  historicalRetention String
  derivedDataRights   String
  displayRights       String
  redistribution      String
  commercialUse       String
  rateLimitPerMinute  Int                      @default(0)
  approvalStatus      DataSourceApprovalStatus @default(NOT_REVIEWED)
  reviewedAt          DateTime?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt

  sources Source[]

  @@unique([provider, dataset])
  @@index([approvalStatus])
}

/// A monitored, read-only ingestion source.
model Source {
  id                        String                  @id @default(cuid())
  kind                      SourceKind
  name                      String
  dataSourceConfigurationId String
  dataSourceConfiguration   DataSourceConfiguration @relation(fields: [dataSourceConfigurationId], references: [id])
  enabled                   Boolean                 @default(false)
  createdAt                 DateTime                @default(now())
  updatedAt                 DateTime                @updatedAt

  contents SourceContent[]
  signals  Signal[]

  @@index([dataSourceConfigurationId])
  @@index([kind])
}

/// Raw content pulled from a source. Append-only; deduplicated per source on
/// contentHash. Treated as hostile data.
model SourceContent {
  id          String    @id @default(cuid())
  sourceId    String
  source      Source    @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  contentHash String
  rawText     String
  publishedAt DateTime?
  fetchedAt   DateTime  @default(now())
  metadata    Json?

  signals     Signal[]
  disclosures CongressionalDisclosure[]

  @@unique([sourceId, contentHash])
  @@index([sourceId])
  @@index([fetchedAt])
}

/// A structured signal extracted from source content by the Signal Analysis
/// agent. Always a validated object — never free text from the model or source.
model Signal {
  id              String        @id @default(cuid())
  sourceId        String
  source          Source        @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  sourceContentId String
  sourceContent   SourceContent @relation(fields: [sourceContentId], references: [id], onDelete: Cascade)
  symbol          String?
  summary         String
  confidence      Float
  status          SignalStatus  @default(NEW)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([sourceId])
  @@index([sourceContentId])
  @@index([status])
  @@index([symbol])
}

/// A structured congressional periodic-transaction-report line (M6), parsed from
/// an official filing held as SourceContent. Amounts are reported as a range and
/// stored as integer cents. Mirrors CongressionalDisclosure in @signalguard/domain.
model CongressionalDisclosure {
  id               String                       @id @default(cuid())
  sourceContentId  String
  sourceContent    SourceContent                @relation(fields: [sourceContentId], references: [id], onDelete: Cascade)
  representative   String
  chamber          Chamber
  symbol           String?
  assetDescription String
  transactionType  CongressionalTransactionType
  amountRangeLow   Int
  amountRangeHigh  Int
  transactionDate  DateTime
  filedDate        DateTime
  createdAt        DateTime                     @default(now())
  updatedAt        DateTime                     @updatedAt

  @@index([sourceContentId])
  @@index([symbol])
  @@index([representative])
  @@index([transactionDate])
}

/// One snapshot of the M7 deterministic analyses (technical indicators + market
/// regime + manipulation detectors) for a single symbol at a single point in
/// time. Written by the watchlist-analysis worker; read by the dashboard.
///
/// Stores integer cents for monetary values (matches market-data /
/// broker-adapters conventions); indicator outputs and regime ratios are
/// floats because they are intermediate analysis values, not money.
///
/// Fields are nullable when the bar history at compute time was shorter than
/// the analyzer's warmup window — the consumer can render "—" rather than
/// having to track warmup math.
model TechnicalAnalysisSnapshot {
  id                  String   @id @default(cuid())
  symbol              String
  computedAt          DateTime
  /// One of "1m" | "5m" | "15m" | "1h" | "1d" — matches BarInterval in
  /// @signalguard/market-data.
  barInterval         String
  barCount            Int
  latestBarTimestamp  DateTime?
  latestBarCloseCents Int?

  // Technical indicators
  sma20               Float?
  ema20               Float?
  rsi14               Float?
  macd                Float?
  macdSignal          Float?
  macdHistogram       Float?
  bollingerUpper      Float?
  bollingerMiddle     Float?
  bollingerLower      Float?

  // Two-dimensional market regime
  trendRegime         String?
  volatilityRegime    String?

  // Manipulation detector outputs (always populated; false on warmup)
  unusualVolume       Boolean
  pumpAndDump         Boolean
  gapAndFade          Boolean

  createdAt           DateTime @default(now())

  @@index([symbol, computedAt(sort: Desc)])
  @@index([computedAt(sort: Desc)])
}

/// One ManipulationAlert per detector-flag transition (false -> true) on a
/// TechnicalAnalysisSnapshot. Surfaces the moment a manipulation pattern
/// FIRST fires for a symbol on a given bar interval — repeated true-true
/// snapshots do NOT emit additional alerts, which keeps the feed quiet on
/// long-running detections.
model ManipulationAlert {
  id           String   @id @default(cuid())
  symbol       String
  /// One of "UNUSUAL_VOLUME" | "PUMP_AND_DUMP" | "GAP_AND_FADE". String
  /// (not a Prisma enum) so adding detectors later is migration-free.
  alertType    String
  triggeredAt  DateTime
  /// Cuid of the TechnicalAnalysisSnapshot row that fired the transition.
  /// Plain string FK-style (no relation) to keep the alert insert decoupled
  /// from a Prisma include/connect dance.
  snapshotId   String
  acknowledged Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([symbol, triggeredAt(sort: Desc)])
  @@index([acknowledged, triggeredAt(sort: Desc)])
}

/// M11 trade proposal. A proposal records the candidate entry/stop/target
/// the proposal layer produced from a snapshot + risk profile + (optionally)
/// a historical scan; the owner approves / rejects in the UI before any
/// order ever reaches the restricted trading worker. PAPER ONLY (AGENTS.md
/// s2) — no field encodes anything that could be interpreted as a live
/// trade.
enum TradeProposalStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  EXPIRED
  CANCELED
}

model TradeProposal {
  id                String              @id @default(cuid())
  symbol            String
  snapshotId        String?
  riskProfile       String
  entryCents        Int
  stopCents         Int
  targetCents       Int
  horizonBars       Int
  sampleSize        Int                 @default(0)
  pTargetFirstPoint Float?
  pTargetFirstLower Float?
  pTargetFirstUpper Float?
  confidence        String
  status            TradeProposalStatus @default(DRAFT)
  // Deterministically-sized share count, set when the owner approves (null
  // until then). This is an approval-time CEILING, not a cleared order size:
  // account equity/cash/positions drift before M12 submission, so the
  // execution layer must submit min(quantity, freshly-resized) and re-run the
  // risk engine. The owner may REDUCE this autonomously (AGENTS.md §2);
  // increasing it requires re-approval. APPROVED with a quantity is NOT
  // clearance to trade.
  quantity          Int?
  notes             String?
  /// Provenance: "DETERMINISTIC" (M9 scan, default) | "TRADING_AGENTS" (LLM
  /// symbol nominator, re-scanned by us). A string (not enum) so new sources are
  /// migration-free. NEVER changes how the gate/sizing/risk engine treat the row.
  source            String              @default("DETERMINISTIC")
  /// AI plain-English rationale (the "AI half" of the analysis gate), generated
  /// once by a background cron. Null = not yet generated / unavailable. Display
  /// only — never gates anything.
  aiSummary         String?
  /// TradingAgents' OWN BUY/SELL/HOLD opinion carried from the candidate —
  /// DISTINCT from the originating intent. Display/conflict metadata only;
  /// NEVER affects the gate, sizing, or risk engine.
  taVerdict         String?
  /// The multi-LLM vote tally carried from the candidate. Display only.
  consensusTally    Json?
  /// The full analyst reports carried from the candidate. Display only.
  analysisReport    Json?
  /// Phase 5 "Fuse" advisory label: a SUBTRACTIVE reconciliation of the
  /// SignalGuard BUY intent vs TradingAgents' verdict vs the multi-LLM
  /// consensus, shaped { tier: "aligned"|"flag"|"escalate"; note: string }.
  /// Display/advisory ONLY — it NEVER gates anything: it cannot change
  /// entry/stop/target/sizing/probability/confidence, cannot change status or
  /// promote the proposal, and cannot cause execution. It can only annotate or
  /// downgrade/escalate, never upgrade. Null = nothing to fuse.
  fuseVerdict       Json?
  expiresAt         DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  orders            Order[]

  @@index([symbol, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
  @@index([source, createdAt(sort: Desc)])
}

/// M12 paper order lifecycle state. Mirrors OrderState in @signalguard/orders —
/// keep the two in sync. PAPER ONLY (AGENTS.md §2). RISK_BLOCKED means OUR
/// deterministic risk engine blocked the order at authorization and it NEVER
/// reached the broker; REJECTED means the BROKER rejected an order we actually
/// submitted. UNKNOWN absorbs broker ambiguity and is resolved by reconciliation
/// querying the broker — never by resubmitting (AGENTS.md §2).
enum OrderState {
  PENDING_AUTHORIZATION
  AUTHORIZED
  SUBMITTED
  ACCEPTED
  PARTIALLY_FILLED
  FILLED
  CANCELED
  REJECTED
  EXPIRED
  RISK_BLOCKED
  UNKNOWN
}

/// M12 paper order. Created at authorization time from an APPROVED TradeProposal
/// and driven through the OrderState machine by the restricted execution worker
/// and the reconciliation job. PAPER ONLY (AGENTS.md §2) — long-only, side is
/// always "BUY", money is integer cents, and no field encodes anything that
/// could be interpreted as a live trade.
enum OrderKind {
  ENTRY
  STOP
  TARGET
  TIME_EXIT
}

model Order {
  id                  String        @id @default(cuid())
  proposalId          String
  proposal            TradeProposal @relation(fields: [proposalId], references: [id])
  symbol              String
  /// "BUY" for an entry; "SELL" for a position-REDUCING exit (M13). Still
  /// long-only (AGENTS.md §2): a SELL only ever reduces a held long and can
  /// never exceed it (the oversell invariant) — it is never a short entry.
  side                String        @default("BUY")
  /// ENTRY (the M12 buy) or an exit leg: STOP / TARGET / TIME_EXIT (M13).
  orderKind           OrderKind     @default(ENTRY)
  /// For exit orders: the Position being reduced (FK-style string). Null for entries.
  parentPositionId    String?
  /// Stop+target legs submitted as a broker OCO share this id, so the oversell
  /// guard counts the pair ONCE. Null for entries and standalone exits.
  ocoGroupId          String?
  quantity            Int
  entryPriceCents     Int
  stopPriceCents      Int?
  timeInForce         String        @default("DAY")
  status              OrderState    @default(PENDING_AUTHORIZATION)
  /// THE idempotency key. Minted once at authorization and reused on every
  /// retry so the broker dedupes; recovery is "query by clientOrderId +
  /// reconcile", NEVER resubmit (AGENTS.md §2). Unique so a duplicate create is
  /// rejected by the database, not just by application logic.
  clientOrderId       String        @unique
  /// The broker's own order id, learned after the order is accepted. Null until
  /// then.
  brokerOrderId       String?
  filledQuantity      Int           @default(0)
  filledAvgPriceCents Int?
  /// Why our risk engine blocked this order (set with status = RISK_BLOCKED).
  riskBlockReason     String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@index([status, createdAt(sort: Desc)])
  @@index([proposalId])
  @@index([parentPositionId])
}

enum PositionStatus {
  OPEN
  CLOSING
  CLOSED
}

/// Operator-facing urgency for in-app notifications (M15). Mirrors the
/// NotificationSeverity union in @signalguard/notifications.
enum NotificationSeverity {
  INFO
  WARNING
  CRITICAL
}

/// One in-app notification (M15). Written by the briefing cron (a daily
/// "briefing.evening" digest) and, later, by critical-alert paths. The owner
/// reads these on /notifications and acknowledges them (read/readAt). PAPER
/// ONLY — purely a read/notify surface; nothing here ever touches orders or
/// broker credentials. `title`/`body` are pre-rendered, secret-free text;
/// any symbol or ingested free text they contain is HTML-escaped at the email
/// boundary, never trusted as markup (AGENTS.md §2).
model Notification {
  id        String               @id @default(cuid())
  /// Optional owner the notification is attributed to. Single-owner today, so
  /// the cron writes null and the unread count spans all rows.
  ownerId   String?
  /// Stable event key, e.g. "briefing.evening" | "alert.manipulation". String
  /// (not a Prisma enum) so adding notification types later is migration-free.
  type      String
  severity  NotificationSeverity @default(INFO)
  title     String
  body      String
  read      Boolean              @default(false)
  createdAt DateTime             @default(now())
  readAt    DateTime?

  @@index([read, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
}

/// A held LONG paper position, opened by a filled entry order (M13). PAPER ONLY,
/// long-only. `quantity` is the live source of truth that protective exits are
/// sized against (it shrinks as exits fill) — never sell more than this across
/// all exit orders (the oversell invariant). Realized P&L is M14.
model Position {
  id                 String         @id @default(cuid())
  symbol             String
  /// Net shares currently held. Shrinks as exit orders fill; 0 => CLOSED.
  quantity           Int
  avgEntryPriceCents Int
  /// The filled entry order that opened this position (FK-style string, mirrors
  /// TradeProposal.snapshotId). Unique: one position per entry order.
  entryOrderId       String         @unique
  /// Protective levels carried from the proposal, used to place the OCO exits.
  stopCents          Int
  targetCents        Int
  status             PositionStatus @default(OPEN)
  openedAt           DateTime       @default(now())
  closedAt           DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([status])
  @@index([symbol])
}
