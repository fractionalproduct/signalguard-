// SignalGuard AI — initial data model (Milestone 1).
// Expanded in later milestones (signals, orders, positions, performance, etc.).
// PostgreSQL is the system of record (see docs/architecture.md).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Pooled connection (Supabase transaction pooler, port 6543) for app runtime.
  url       = env("DATABASE_URL")
  // Direct/session connection (port 5432) for migrations & `prisma db push`.
  directUrl = env("DIRECT_URL")
}

/// The single platform owner. Public registration is disabled; the owner is
/// created once via `pnpm create-owner` (Milestone 2). Passwords and MFA secrets
/// are stored hashed/encrypted only — never plaintext.
model Owner {
  id                 String    @id @default(cuid())
  email              String    @unique
  passwordHash       String?
  mfaEnabled         Boolean   @default(false)
  /// TOTP secret, encrypted at rest (AES-256-GCM). Never stored in plaintext.
  mfaSecretEncrypted String?
  mfaEnabledAt       DateTime?
  passwordChangedAt  DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  auditEvents         AuditEvent[]
  sessions            Session[]
  recoveryCodes       RecoveryCode[]
  passwordResetTokens PasswordResetToken[]
}

/// An authenticated browser session. The raw token lives only in the owner's
/// HTTP-only cookie; only its SHA-256 hash is stored here.
model Session {
  id         String    @id @default(cuid())
  ownerId    String
  owner      Owner     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique
  createdAt  DateTime  @default(now())
  expiresAt  DateTime
  lastUsedAt DateTime?
  revokedAt  DateTime?
  ipAddress  String?
  userAgent  String?

  @@index([ownerId])
  @@index([expiresAt])
}

/// One-time MFA recovery codes. Only the hash is stored; consumed on use.
model RecoveryCode {
  id        String    @id @default(cuid())
  ownerId   String
  owner     Owner     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  codeHash  String
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([ownerId])
}

/// Short-lived password-reset tokens. Raw token emailed; only its hash stored.
model PasswordResetToken {
  id        String    @id @default(cuid())
  ownerId   String
  owner     Owner     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([ownerId])
}

/// Append-only audit trail. Every security-, trading-, and guardrail-sensitive
/// action writes a record here. Records are never updated or deleted.
model AuditEvent {
  id        String   @id @default(cuid())
  /// Stable event type, e.g. "owner.login", "emergency_stop.activated".
  type      String
  /// Logical service that emitted the event: web | general-worker | trading-worker.
  source    String
  /// Optional actor (owner) the event is attributed to.
  ownerId   String?
  owner     Owner?   @relation(fields: [ownerId], references: [id])
  /// Free-form structured context (no secrets).
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([type])
  @@index([createdAt])
  @@index([ownerId])
}

// --- Milestone 5: source intelligence & signals --------------------------------
// Mirrors the types in @signalguard/domain. Source content is treated as hostile
// data; instructions inside it are never executed (AGENTS.md §2). No connector
// runs without an APPROVED_FOR_PRODUCTION DataSourceConfiguration in production
// (AGENTS.md §15, docs/data-licensing.md).

/// Licensing approval for a data provider/dataset. The authoritative enum lives
/// in @signalguard/domain (DataSourceApprovalStatus) — keep the two in sync.
enum DataSourceApprovalStatus {
  NOT_REVIEWED
  PENDING_REVIEW
  APPROVED_FOR_DEVELOPMENT
  APPROVED_FOR_PRODUCTION
  REJECTED
  SUSPENDED
}

/// How a source's content is obtained. Only MANUAL and MOCK run in the MVP.
enum SourceKind {
  MANUAL
  MOCK
  X
  TELEGRAM
  RSS
  CONGRESS
}

/// Congressional chamber a filing originates from (M6).
enum Chamber {
  HOUSE
  SENATE
}

/// Reported transaction type on a congressional periodic transaction report.
enum CongressionalTransactionType {
  PURCHASE
  SALE
  EXCHANGE
}

/// Lifecycle of an extracted signal. Mirrors SignalStatus in @signalguard/domain.
enum SignalStatus {
  NEW
  PROCESSING
  READY_FOR_REVIEW
  APPROVED
  REJECTED
  EXPIRED
  ARCHIVED
}

/// Per-provider licensing record. Every Source references exactly one; no
/// connector runs without it, and production needs APPROVED_FOR_PRODUCTION.
model DataSourceConfiguration {
  id                  String                   @id @default(cuid())
  provider            String
  dataset             String
  terms               String
  permittedUses       String
  prohibitedUses      String
  storageRights       String
  historicalRetention String
  derivedDataRights   String
  displayRights       String
  redistribution      String
  commercialUse       String
  rateLimitPerMinute  Int                      @default(0)
  approvalStatus      DataSourceApprovalStatus @default(NOT_REVIEWED)
  reviewedAt          DateTime?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt

  sources Source[]

  @@unique([provider, dataset])
  @@index([approvalStatus])
}

/// A monitored, read-only ingestion source.
model Source {
  id                        String                  @id @default(cuid())
  kind                      SourceKind
  name                      String
  dataSourceConfigurationId String
  dataSourceConfiguration   DataSourceConfiguration @relation(fields: [dataSourceConfigurationId], references: [id])
  enabled                   Boolean                 @default(false)
  createdAt                 DateTime                @default(now())
  updatedAt                 DateTime                @updatedAt

  contents SourceContent[]
  signals  Signal[]

  @@index([dataSourceConfigurationId])
  @@index([kind])
}

/// Raw content pulled from a source. Append-only; deduplicated per source on
/// contentHash. Treated as hostile data.
model SourceContent {
  id          String    @id @default(cuid())
  sourceId    String
  source      Source    @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  contentHash String
  rawText     String
  publishedAt DateTime?
  fetchedAt   DateTime  @default(now())
  metadata    Json?

  signals     Signal[]
  disclosures CongressionalDisclosure[]

  @@unique([sourceId, contentHash])
  @@index([sourceId])
  @@index([fetchedAt])
}

/// A structured signal extracted from source content by the Signal Analysis
/// agent. Always a validated object — never free text from the model or source.
model Signal {
  id              String        @id @default(cuid())
  sourceId        String
  source          Source        @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  sourceContentId String
  sourceContent   SourceContent @relation(fields: [sourceContentId], references: [id], onDelete: Cascade)
  symbol          String?
  summary         String
  confidence      Float
  status          SignalStatus  @default(NEW)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([sourceId])
  @@index([sourceContentId])
  @@index([status])
  @@index([symbol])
}

/// A structured congressional periodic-transaction-report line (M6), parsed from
/// an official filing held as SourceContent. Amounts are reported as a range and
/// stored as integer cents. Mirrors CongressionalDisclosure in @signalguard/domain.
model CongressionalDisclosure {
  id               String                       @id @default(cuid())
  sourceContentId  String
  sourceContent    SourceContent                @relation(fields: [sourceContentId], references: [id], onDelete: Cascade)
  representative   String
  chamber          Chamber
  symbol           String?
  assetDescription String
  transactionType  CongressionalTransactionType
  amountRangeLow   Int
  amountRangeHigh  Int
  transactionDate  DateTime
  filedDate        DateTime
  createdAt        DateTime                     @default(now())
  updatedAt        DateTime                     @updatedAt

  @@index([sourceContentId])
  @@index([symbol])
  @@index([representative])
  @@index([transactionDate])
}

/// One snapshot of the M7 deterministic analyses (technical indicators + market
/// regime + manipulation detectors) for a single symbol at a single point in
/// time. Written by the watchlist-analysis worker; read by the dashboard.
///
/// Stores integer cents for monetary values (matches market-data /
/// broker-adapters conventions); indicator outputs and regime ratios are
/// floats because they are intermediate analysis values, not money.
///
/// Fields are nullable when the bar history at compute time was shorter than
/// the analyzer's warmup window — the consumer can render "—" rather than
/// having to track warmup math.
model TechnicalAnalysisSnapshot {
  id                  String   @id @default(cuid())
  symbol              String
  computedAt          DateTime
  /// One of "1m" | "5m" | "15m" | "1h" | "1d" — matches BarInterval in
  /// @signalguard/market-data.
  barInterval         String
  barCount            Int
  latestBarTimestamp  DateTime?
  latestBarCloseCents Int?

  // Technical indicators
  sma20               Float?
  ema20               Float?
  rsi14               Float?
  macd                Float?
  macdSignal          Float?
  macdHistogram       Float?
  bollingerUpper      Float?
  bollingerMiddle     Float?
  bollingerLower      Float?

  // Two-dimensional market regime
  trendRegime         String?
  volatilityRegime    String?

  // Manipulation detector outputs (always populated; false on warmup)
  unusualVolume       Boolean
  pumpAndDump         Boolean
  gapAndFade          Boolean

  createdAt           DateTime @default(now())

  @@index([symbol, computedAt(sort: Desc)])
  @@index([computedAt(sort: Desc)])
}

/// One ManipulationAlert per detector-flag transition (false -> true) on a
/// TechnicalAnalysisSnapshot. Surfaces the moment a manipulation pattern
/// FIRST fires for a symbol on a given bar interval — repeated true-true
/// snapshots do NOT emit additional alerts, which keeps the feed quiet on
/// long-running detections.
model ManipulationAlert {
  id           String   @id @default(cuid())
  symbol       String
  /// One of "UNUSUAL_VOLUME" | "PUMP_AND_DUMP" | "GAP_AND_FADE". String
  /// (not a Prisma enum) so adding detectors later is migration-free.
  alertType    String
  triggeredAt  DateTime
  /// Cuid of the TechnicalAnalysisSnapshot row that fired the transition.
  /// Plain string FK-style (no relation) to keep the alert insert decoupled
  /// from a Prisma include/connect dance.
  snapshotId   String
  acknowledged Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([symbol, triggeredAt(sort: Desc)])
  @@index([acknowledged, triggeredAt(sort: Desc)])
}

/// M11 trade proposal. A proposal records the candidate entry/stop/target
/// the proposal layer produced from a snapshot + risk profile + (optionally)
/// a historical scan; the owner approves / rejects in the UI before any
/// order ever reaches the restricted trading worker. PAPER ONLY (AGENTS.md
/// s2) — no field encodes anything that could be interpreted as a live
/// trade.
enum TradeProposalStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  EXPIRED
}

model TradeProposal {
  id                String              @id @default(cuid())
  symbol            String
  snapshotId        String?
  riskProfile       String
  entryCents        Int
  stopCents         Int
  targetCents       Int
  horizonBars       Int
  sampleSize        Int                 @default(0)
  pTargetFirstPoint Float?
  pTargetFirstLower Float?
  pTargetFirstUpper Float?
  confidence        String
  status            TradeProposalStatus @default(DRAFT)
  notes             String?
  expiresAt         DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([symbol, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
}
