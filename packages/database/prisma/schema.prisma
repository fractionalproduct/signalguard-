// SignalGuard AI — initial data model (Milestone 1).
// Expanded in later milestones (signals, orders, positions, performance, etc.).
// PostgreSQL is the system of record (see docs/architecture.md).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Pooled connection (Supabase transaction pooler, port 6543) for app runtime.
  url       = env("DATABASE_URL")
  // Direct/session connection (port 5432) for migrations & `prisma db push`.
  directUrl = env("DIRECT_URL")
}

/// The single platform owner. Public registration is disabled; the owner is
/// created once via `pnpm create-owner` (Milestone 2). Passwords and MFA secrets
/// are stored hashed/encrypted only — never plaintext.
model Owner {
  id                 String    @id @default(cuid())
  email              String    @unique
  passwordHash       String?
  mfaEnabled         Boolean   @default(false)
  /// TOTP secret, encrypted at rest (AES-256-GCM). Never stored in plaintext.
  mfaSecretEncrypted String?
  mfaEnabledAt       DateTime?
  passwordChangedAt  DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  auditEvents         AuditEvent[]
  sessions            Session[]
  recoveryCodes       RecoveryCode[]
  passwordResetTokens PasswordResetToken[]
}

/// An authenticated browser session. The raw token lives only in the owner's
/// HTTP-only cookie; only its SHA-256 hash is stored here.
model Session {
  id         String    @id @default(cuid())
  ownerId    String
  owner      Owner     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique
  createdAt  DateTime  @default(now())
  expiresAt  DateTime
  lastUsedAt DateTime?
  revokedAt  DateTime?
  ipAddress  String?
  userAgent  String?

  @@index([ownerId])
  @@index([expiresAt])
}

/// One-time MFA recovery codes. Only the hash is stored; consumed on use.
model RecoveryCode {
  id        String    @id @default(cuid())
  ownerId   String
  owner     Owner     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  codeHash  String
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([ownerId])
}

/// Short-lived password-reset tokens. Raw token emailed; only its hash stored.
model PasswordResetToken {
  id        String    @id @default(cuid())
  ownerId   String
  owner     Owner     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([ownerId])
}

/// Append-only audit trail. Every security-, trading-, and guardrail-sensitive
/// action writes a record here. Records are never updated or deleted.
model AuditEvent {
  id          String   @id @default(cuid())
  /// Stable event type, e.g. "owner.login", "emergency_stop.activated".
  type        String
  /// Logical service that emitted the event: web | general-worker | trading-worker.
  source      String
  /// Optional actor (owner) the event is attributed to.
  ownerId     String?
  owner       Owner?   @relation(fields: [ownerId], references: [id])
  /// Free-form structured context (no secrets).
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([type])
  @@index([createdAt])
  @@index([ownerId])
}
